# .gitignore — slep_idps (RAMA A: proyecto publico, datos versionados)
# Los datos son agregados publicos de la Agencia de Calidad y se versionan
# dentro del repo. Por eso NO se incluye el bloque de exclusion de datos.

# Credenciales
.env
.Renviron
*credentials*
*secret*
*token*
*password*

# Sistema
.Rproj.user/
.Rhistory
.RData
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db
# Nota: *.Rproj SI se versiona (ancla del proyecto; sin el, here::here() no
# resuelve en otra maquina). Solo .Rproj.user/ se ignora.

# Snapshots y backups locales
_archivo/
*.bak

# Outputs accidentales en raiz y scripts de diagnostico
/*.docx
/*.pdf
diagnostico_*.md
/verificar_*.R
/listar_*.R

# Intermedios scratch no reproducibles por el pipeline.
# Los inventarios fueron generados por encargos one-off (s11); ningun script
# del flujo (00_build.R, 30_procesamiento/) los regenera, por lo que no son
# trazables y no se versionan. El resto de 40_salidas/intermedios/ (parquets
# del pipeline: idps_largo, catalogo_idps, etc.) SI se versiona.
40_salidas/intermedios/inventario_*.parquet

# Outputs temporales
*_freeze/
.quarto/
20_insumos/auxiliares/directorio_oficial_ee.csv
